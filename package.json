{
  "name": "element-ui-pro-components",
  "version": "1.5.0",
  "description": "Vue 2 + Element UI Pro Components: ProForm, DialogForm, ProTable, EditableProTable.",
  "main": "lib/element-ui-pro-components.common.js",
  "files": [
    "lib",
    "src",
    "packages",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:umd": "node build/bin/build-locale.js",
    "build:utils": "cross-env BABEL_ENV=utils babel src --out-dir lib --ignore src/index.js",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "examples:dev": "webpack-dev-server --config build/webpack.dev.js",
    "lib:build": "webpack --config build/webpack.common.js && webpack --config build/webpack.component.js && npm run build:utils && npm run build:umd"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gameorstudy/element-ui-pro-components"
  },
  "keywords": [
    "element",
    "element-ui",
    "pro-components",
    "vue2",
    "pro-form",
    "dialog-form",
    "pro-table",
    "editable-pro-table"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gameorstudy/element-ui-pro-components/issues"
  },
  "style": "lib/index.css",
  "peerDependencies": {
    "el-table-prepend": "^1.3.2",
    "element-ui": "^2.15.14",
    "vue": "^2.6.10",
    "vue-fragment": "^1.6.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@vue/babel-preset-jsx": "^1.4.0",
    "babel-loader": "^8.3.0",
    "cross-env": "^10.1.0",
    "css-loader": "^2.1.0",
    "el-table-prepend": "^1.3.2",
    "element-ui": "^2.15.14",
    "html-webpack-plugin": "^4.5.2",
    "less": "^4.6.4",
    "less-loader": "^7.3.0",
    "mini-css-extract-plugin": "^1.6.2",
    "null-loader": "^4.0.1",
    "optimize-css-assets-webpack-plugin": "^6.0.1",
    "progress-bar-webpack-plugin": "^2.1.0",
    "style-loader": "^2.0.0",
    "terser-webpack-plugin": "^4.2.3",
    "url-loader": "^4.1.1",
    "vue": "^2.6.10",
    "vue-fragment": "^1.6.0",
    "vue-loader": "^15.10.0",
    "vue-template-compiler": "^2.6.10",
    "vuepress": "^1.9.10",
    "webpack": "^4.14.0",
    "webpack-cli": "^3.0.8",
    "webpack-dev-server": "^3.11.3"
  },
  "dependencies": {
    "babel-plugin-module-resolver": "^5.0.3"
  }
}
